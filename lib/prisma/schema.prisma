generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id        String   @id @default(cuid())
  consentId String   @unique
  status    String
  userAgent String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
